# VoltGrid API — variables de entorno (copiar a .env y rellenar)

# Entorno: dev | prod
ENV=dev

# --- Base de datos ---
# DSN async (asyncpg) que usa la aplicación. Debe ser un rol NO superusuario (RLS).
DATABASE_URL=postgresql+asyncpg://voltgrid:voltgrid@localhost:5432/voltgrid
# DSN sync (psycopg) para el jobstore de APScheduler. Misma base, driver sync.
SYNC_DATABASE_URL=postgresql+psycopg://voltgrid:voltgrid@localhost:5432/voltgrid

# --- JWT ---
JWT_SECRET=cambia-esto-por-una-clave-larga-y-aleatoria
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- SSO / sesión (Authlib) ---
SESSION_SECRET_KEY=cambia-esto-tambien
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
# Google OAuth (Google Cloud Console -> Credentials -> OAuth client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft (Azure App Registration). TENANT=common para multi-tenant.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Scheduler ---
# true solo en el proceso/deployment dedicado a scheduling (replicas=1).
SCHEDULER_ENABLED=true

# --- Migraciones (entrypoint Docker) ---
RUN_MIGRATIONS=true

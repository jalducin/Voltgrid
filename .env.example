# =============================================================================
# VoltGrid — variables de entorno del monorepo (raíz). Copiar a `.env` y rellenar.
# El archivo `.env` está gitignored; este `.env.example` se versiona SIN secretos reales.
# Lo consume docker-compose.yml (postgres, migrate, api, scheduler, web).
# =============================================================================

# --- PostgreSQL (rol ADMIN / superusuario de la imagen) ---
# Este rol es dueño de la base y corre las migraciones. NO lo usa la app en runtime.
POSTGRES_USER=voltgrid
POSTGRES_PASSWORD=voltgrid
POSTGRES_DB=voltgrid

# --- Rol de aplicación (NO superusuario; RLS aplica) ---
# Debe coincidir con la contraseña del CREATE ROLE en infra/postgres/init/01-init.sql.
VOLTGRID_APP_PASSWORD=voltgrid_app

# --- Entorno de la API ---
ENV=dev

# --- JWT ---
JWT_SECRET=cambia-esto-por-una-clave-larga-y-aleatoria
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- SSO / sesión (Authlib) ---
SESSION_SECRET_KEY=cambia-esto-tambien
OAUTH_REDIRECT_BASE_URL=http://localhost:8000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# --- CORS ---
CORS_ORIGINS=http://localhost:3000

# --- Frontend (build arg, se hornea en la imagen web) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
